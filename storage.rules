rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /lottie/{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
  }
}
